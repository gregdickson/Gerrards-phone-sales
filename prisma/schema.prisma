generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STAFF
  ADMIN
}

enum SubmissionStatus {
  PROCESSING
  COMPLETE
  FAILED
}

enum SubmissionStep {
  GHL_CONTACT
  GHL_TAG
  GHL_CONTACT_NOTE
  STAFF_WEBHOOK
  GHL_OPPORTUNITY
  FOLIO
}

enum ConversionOutcome {
  WON
  LOST
}

enum BusinessType {
  NEW_BUSINESS
  RENEWAL
}

enum LostReason {
  WENT_DIRECT
  PRICE
  INCUMBENT_BROKER
  NO_APPETITE
  CUSTOMER_WITHDREW
  OTHER
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  ghlUserId    String    @map("ghl_user_id")
  webhookUrl   String?   @map("webhook_url")
  role         Role      @default(STAFF)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  magicLinks   MagicLinkToken[]
  sessions     Session[]
  submissions  Submission[]
  conversions  Conversion[]

  @@map("users")
}

model MagicLinkToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique @map("token_hash")
  userId     String    @map("user_id")
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("magic_link_tokens")
}

model Session {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  expiresAt   DateTime @map("expires_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model InsuranceCategory {
  id            String   @id @default(cuid())
  slug          String   @unique
  label         String
  utmCampaign   String   @map("utm_campaign")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  submissions   Submission[]
  conversions   Conversion[]

  @@map("insurance_categories")
}

model LeadSource {
  id          String   @id @default(cuid())
  label       String   @unique
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  submissions Submission[]

  @@map("lead_sources")
}

model Submission {
  id                    String            @id @default(cuid())
  salespersonUserId     String            @map("salesperson_user_id")
  insuranceCategoryId   String            @map("insurance_category_id")
  leadSourceId          String            @map("lead_source_id")

  leadFirstName         String            @map("lead_first_name")
  leadLastName          String            @map("lead_last_name")
  leadEmail             String            @map("lead_email")
  leadPhone             String            @map("lead_phone")
  organisation          String?
  addressLine           String?           @map("address_line")
  city                  String?
  state                 String?
  country               String?           @default("NZ")
  postalCode            String?           @map("postal_code")
  notes                 String

  status                SubmissionStatus  @default(PROCESSING)
  ghlContactId          String?           @map("ghl_contact_id")
  ghlOpportunityId      String?           @map("ghl_opportunity_id")
  webhookResponseStatus Int?              @map("webhook_response_status")

  // Per-form idempotency key. Unique constraint blocks duplicate rows from
  // double-clicks / back-button resubmits even under a concurrent race.
  submitToken           String?           @unique @map("submit_token")

  createdAt             DateTime          @default(now()) @map("created_at")
  completedAt           DateTime?         @map("completed_at")

  salesperson           User              @relation(fields: [salespersonUserId], references: [id])
  category              InsuranceCategory @relation(fields: [insuranceCategoryId], references: [id])
  leadSource            LeadSource        @relation(fields: [leadSourceId], references: [id])
  events                SubmissionEvent[]

  @@index([salespersonUserId])
  @@index([createdAt])
  @@index([status])
  @@map("submissions")
}

model SubmissionEvent {
  id              String          @id @default(cuid())
  submissionId    String          @map("submission_id")
  step            SubmissionStep
  succeeded       Boolean
  responseStatus  Int?            @map("response_status")
  responseBody    String?         @map("response_body")
  errorMessage    String?         @map("error_message")
  createdAt       DateTime        @default(now()) @map("created_at")

  submission      Submission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("submission_events")
}

// Insurers (underwriters) a broker can place business with. Admin-editable,
// mirrors the LeadSource pattern. defaultCommissionPct pre-fills the brokerage
// calc on the conversion form so the broker doesn't type the percentage.
model Insurer {
  id                   String   @id @default(cuid())
  label                String   @unique
  sortOrder            Int      @default(0) @map("sort_order")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")

  conversions          Conversion[]

  @@map("insurers")
}

// A won/lost outcome logged by a broker once a lead is closed. Standalone (not
// every win originates as a Submission in this app — Google Ads leads come
// through the lead-distribution system). Optionally links back to a Submission
// for pre-fill and stores GHL ids so the outcome can be written back to GHL and
// the enquiry → win funnel can be joined on the dashboard. Dollar figures are
// the broker's estimate at bind; CBN reconciles actuals later.
model Conversion {
  id                  String            @id @default(cuid())
  // Nullable: lost rows synced from GHL may be assigned to a GHL user who is
  // not an app user, so we keep ghlAssignedTo and leave broker unlinked.
  brokerUserId        String?           @map("broker_user_id")
  submissionId        String?           @map("submission_id")
  ghlContactId        String?           @map("ghl_contact_id")
  ghlOpportunityId    String?           @map("ghl_opportunity_id")

  clientName          String            @map("client_name")
  outcome             ConversionOutcome

  // --- WON ---
  businessType        BusinessType?     @map("business_type")
  insuranceCategoryId String?           @map("insurance_category_id")
  insurerId           String?           @map("insurer_id")
  policiesBound       Int               @default(1) @map("policies_bound")
  annualPremium       Decimal?          @map("annual_premium")       @db.Decimal(12, 2)
  inceptionDate       DateTime?         @map("inception_date")
  brokerFee           Decimal?          @map("broker_fee")           @db.Decimal(12, 2)

  // --- LOST ---
  lostReason          LostReason?       @map("lost_reason")        // legacy manual enum (unused; lost now from GHL)
  competitor          String?
  // Lost-from-GHL sync fields:
  ghlLostReasonId     String?           @map("ghl_lost_reason_id") // resolve to label via GhlLostReason.ghlId
  ghlAssignedTo       String?           @map("ghl_assigned_to")    // GHL user id of the agent
  lostAt              DateTime?         @map("lost_at")            // GHL lastStatusChangeAt when marked lost
  source              String            @default("FORM") @map("source") // FORM | GHL_SYNC

  notes               String?
  ghlWritebackStatus  Int?              @map("ghl_writeback_status")
  submitToken         String?           @unique @map("submit_token")
  createdAt           DateTime          @default(now()) @map("created_at")

  broker              User?              @relation(fields: [brokerUserId], references: [id])
  category            InsuranceCategory? @relation(fields: [insuranceCategoryId], references: [id])
  insurer             Insurer?           @relation(fields: [insurerId], references: [id])

  @@index([brokerUserId])
  @@index([createdAt])
  @@index([outcome])
  @@index([ghlOpportunityId])
  @@map("conversions")
}

// Auto-discovered GHL lost-reason IDs → human labels. GHL v2 has no endpoint to
// list lost reasons, so the sync inserts each distinct lostReasonId it sees
// (label defaults to the id) and an admin renames it at /admin/lost-reasons.
model GhlLostReason {
  id        String   @id @default(cuid())
  ghlId     String   @unique @map("ghl_id")
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ghl_lost_reasons")
}

// Tiny key/value store for sync cursors (e.g. last lost-sync timestamp).
model SyncState {
  key       String   @id
  value     String?
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("sync_state")
}

// Real won/revenue ledger, imported from CBN "Broker Earnings Detail" xlsx
// exports. Transaction-grained (one row per CBN Tran.Number — the idempotent
// upsert key), so monthly re-imports update cleanly. This is the authoritative
// money source (GWP/fee/commission/GBI) — distinct from `conversions` (deal
// outcomes). Feeds the dashboard's financial panels. CBN carries no insurer or
// class column, so those stay on conversions.
model BrokerEarning {
  id                String    @id @default(cuid())
  tranNumber        String    @unique @map("tran_number")
  brokerName        String    @map("broker_name")             // resolved from file→broker mapping
  brokerUserId      String?   @map("broker_user_id")          // optional hint; matched by name, no FK
  tranDate          DateTime  @map("tran_date")
  effectiveDate     DateTime? @map("effective_date")
  clientName        String?   @map("client_name")
  tranType          String    @map("tran_type")               // New Business | Renewal | Endorsement | Cancellation | ...
  invoiceAmount     Decimal?  @map("invoice_amount")      @db.Decimal(14, 2) // ≈ GWP/premium invoiced
  brokerFee         Decimal?  @map("broker_fee")          @db.Decimal(14, 2)
  brokerCommission  Decimal?  @map("broker_commission")   @db.Decimal(14, 2)
  grossBrokerIncome Decimal?  @map("gross_broker_income") @db.Decimal(14, 2) // GBI — headline production
  netBrokerIncome   Decimal?  @map("net_broker_income")   @db.Decimal(14, 2)
  sourceFile        String?   @map("source_file")
  importedAt        DateTime  @default(now()) @map("imported_at")

  @@index([brokerName])
  @@index([tranDate])
  @@index([tranType])
  @@map("broker_earnings")
}
