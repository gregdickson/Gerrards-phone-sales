<div class="max-w-3xl mx-auto">
  <div class="mb-8 animate-in">
    <h1 class="font-serif text-3xl italic" style="color: var(--brand-dark);">New submission</h1>
    <p class="text-mid text-sm mt-1">Select the insurance category for this lead</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    <% categories.forEach(function(cat, i) { %>
    <a href="/new?category=<%= cat.slug %>"
       class="card group p-5 hover:border-brand transition-all duration-200 hover:shadow-md animate-in"
       style="animation-delay: <%= i * 0.04 %>s">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-brand-light flex items-center justify-center shrink-0 group-hover:bg-brand group-hover:text-white transition-colors">
          <svg class="w-5 h-5 text-brand group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/>
          </svg>
        </div>
        <span class="font-medium text-sm" style="color: var(--brand-dark);"><%= cat.label %></span>
      </div>
    </a>
    <% }); %>
  </div>

  <div class="mt-8 text-center animate-in" style="animation-delay: 0.4s">
    <a href="/my-submissions" class="text-sm text-mid hover:text-brand transition-colors">
      View my recent submissions &rarr;
    </a>
  </div>
</div>
