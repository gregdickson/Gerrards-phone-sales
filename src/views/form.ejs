<div class="max-w-2xl mx-auto animate-in">
  <div class="mb-6">
    <a href="/" class="text-sm text-mid hover:text-brand transition-colors">&larr; Back to categories</a>
    <h1 class="font-serif text-2xl italic mt-2" style="color: var(--brand-dark);">New Lead &mdash; <%= category.label %></h1>
  </div>

  <form method="POST" action="/new" class="card p-6 sm:p-8 space-y-5">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="category_id" value="<%= category.id %>">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="lead_first_name" class="block text-sm font-medium mb-1.5">First Name *</label>
        <input type="text" id="lead_first_name" name="lead_first_name"
               value="<%= typeof values !== 'undefined' && values.lead_first_name ? values.lead_first_name : '' %>"
               required
               class="input-field <%= typeof errors !== 'undefined' && errors.lead_first_name ? 'error' : '' %>">
        <% if (typeof errors !== 'undefined' && errors.lead_first_name) { %>
        <p class="text-red-600 text-xs mt-1"><%= errors.lead_first_name %></p>
        <% } %>
      </div>
      <div>
        <label for="lead_last_name" class="block text-sm font-medium mb-1.5">Last Name *</label>
        <input type="text" id="lead_last_name" name="lead_last_name"
               value="<%= typeof values !== 'undefined' && values.lead_last_name ? values.lead_last_name : '' %>"
               required
               class="input-field <%= typeof errors !== 'undefined' && errors.lead_last_name ? 'error' : '' %>">
        <% if (typeof errors !== 'undefined' && errors.lead_last_name) { %>
        <p class="text-red-600 text-xs mt-1"><%= errors.lead_last_name %></p>
        <% } %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="lead_phone" class="block text-sm font-medium mb-1.5">Phone *</label>
        <input type="tel" id="lead_phone" name="lead_phone"
               value="<%= typeof values !== 'undefined' && values.lead_phone ? values.lead_phone : '' %>"
               required
               class="input-field <%= typeof errors !== 'undefined' && errors.lead_phone ? 'error' : '' %>">
        <% if (typeof errors !== 'undefined' && errors.lead_phone) { %>
        <p class="text-red-600 text-xs mt-1"><%= errors.lead_phone %></p>
        <% } %>
      </div>
      <div>
        <label for="lead_email" class="block text-sm font-medium mb-1.5">Email *</label>
        <input type="email" id="lead_email" name="lead_email"
               value="<%= typeof values !== 'undefined' && values.lead_email ? values.lead_email : '' %>"
               required
               class="input-field <%= typeof errors !== 'undefined' && errors.lead_email ? 'error' : '' %>">
        <% if (typeof errors !== 'undefined' && errors.lead_email) { %>
        <p class="text-red-600 text-xs mt-1"><%= errors.lead_email %></p>
        <% } %>
      </div>
    </div>

    <div>
      <label for="organisation" class="block text-sm font-medium mb-1.5">Organisation *</label>
      <input type="text" id="organisation" name="organisation"
             value="<%= typeof values !== 'undefined' && values.organisation ? values.organisation : '' %>"
             required
             class="input-field <%= typeof errors !== 'undefined' && errors.organisation ? 'error' : '' %>">
      <% if (typeof errors !== 'undefined' && errors.organisation) { %>
      <p class="text-red-600 text-xs mt-1"><%= errors.organisation %></p>
      <% } %>
    </div>

    <div>
      <label for="address_search" class="block text-sm font-medium mb-1.5">Address</label>
      <input type="text" id="address_search" placeholder="Start typing to search..."
             autocomplete="off"
             class="input-field mb-4">

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="sm:col-span-2">
          <label for="street_address" class="block text-sm font-medium mb-1.5">Street Address *</label>
          <input type="text" id="street_address" name="street_address"
                 value="<%= typeof values !== 'undefined' && values.street_address ? values.street_address : '' %>"
                 required autocomplete="off"
                 class="input-field <%= typeof errors !== 'undefined' && errors.street_address ? 'error' : '' %>">
          <% if (typeof errors !== 'undefined' && errors.street_address) { %>
          <p class="text-red-600 text-xs mt-1"><%= errors.street_address %></p>
          <% } %>
        </div>
        <div>
          <label for="city" class="block text-sm font-medium mb-1.5">City *</label>
          <input type="text" id="city" name="city"
                 value="<%= typeof values !== 'undefined' && values.city ? values.city : '' %>"
                 required autocomplete="off"
                 class="input-field <%= typeof errors !== 'undefined' && errors.city ? 'error' : '' %>">
          <% if (typeof errors !== 'undefined' && errors.city) { %>
          <p class="text-red-600 text-xs mt-1"><%= errors.city %></p>
          <% } %>
        </div>
        <div>
          <label for="state" class="block text-sm font-medium mb-1.5">State *</label>
          <input type="text" id="state" name="state"
                 value="<%= typeof values !== 'undefined' && values.state ? values.state : '' %>"
                 required autocomplete="off"
                 class="input-field <%= typeof errors !== 'undefined' && errors.state ? 'error' : '' %>">
          <% if (typeof errors !== 'undefined' && errors.state) { %>
          <p class="text-red-600 text-xs mt-1"><%= errors.state %></p>
          <% } %>
        </div>
        <div>
          <label for="country" class="block text-sm font-medium mb-1.5">Country *</label>
          <input type="text" id="country" name="country"
                 value="<%= typeof values !== 'undefined' && values.country ? values.country : 'NZ' %>"
                 required autocomplete="off"
                 class="input-field <%= typeof errors !== 'undefined' && errors.country ? 'error' : '' %>">
          <% if (typeof errors !== 'undefined' && errors.country) { %>
          <p class="text-red-600 text-xs mt-1"><%= errors.country %></p>
          <% } %>
        </div>
        <div>
          <label for="postal_code" class="block text-sm font-medium mb-1.5">Postal Code *</label>
          <input type="text" id="postal_code" name="postal_code"
                 value="<%= typeof values !== 'undefined' && values.postal_code ? values.postal_code : '' %>"
                 required autocomplete="off"
                 class="input-field <%= typeof errors !== 'undefined' && errors.postal_code ? 'error' : '' %>">
          <% if (typeof errors !== 'undefined' && errors.postal_code) { %>
          <p class="text-red-600 text-xs mt-1"><%= errors.postal_code %></p>
          <% } %>
        </div>
      </div>
    </div>

    <div>
      <label for="lead_source_id" class="block text-sm font-medium mb-1.5">Lead Source *</label>
      <select id="lead_source_id" name="lead_source_id" required
              class="input-field <%= typeof errors !== 'undefined' && errors.lead_source_id ? 'error' : '' %>">
        <option value="">Select...</option>
        <% leadSources.forEach(function(src) { %>
        <option value="<%= src.id %>" <%= (typeof values !== 'undefined' && values.lead_source_id === src.id) ? 'selected' : '' %>><%= src.label %></option>
        <% }); %>
      </select>
      <% if (typeof errors !== 'undefined' && errors.lead_source_id) { %>
      <p class="text-red-600 text-xs mt-1"><%= errors.lead_source_id %></p>
      <% } %>
    </div>

    <div>
      <label for="notes" class="block text-sm font-medium mb-1.5">Notes *</label>
      <textarea id="notes" name="notes" rows="4" required
                class="input-field <%= typeof errors !== 'undefined' && errors.notes ? 'error' : '' %>"><%= typeof values !== 'undefined' && values.notes ? values.notes : '' %></textarea>
      <% if (typeof errors !== 'undefined' && errors.notes) { %>
      <p class="text-red-600 text-xs mt-1"><%= errors.notes %></p>
      <% } %>
    </div>

    <div class="pt-2">
      <button type="submit" class="btn-primary w-full py-3">
        Submit Lead
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
        </svg>
      </button>
    </div>
  </form>
</div>

<script src="/js/places.js"></script>
<script src="https://maps.googleapis.com/maps/api/js?key=<%= googlePlacesApiKey %>&libraries=places&callback=initPlacesAutocomplete" async defer></script>
