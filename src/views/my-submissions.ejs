<div class="max-w-3xl mx-auto">
  <div class="flex items-center justify-between mb-6 animate-in">
    <div>
      <h1 class="font-serif text-2xl italic" style="color: var(--brand-dark);">My Submissions</h1>
      <p class="text-mid text-sm mt-1">Your recent lead submissions</p>
    </div>
    <a href="/" class="btn-secondary text-sm">&larr; Categories</a>
  </div>

  <% if (submissions.length === 0) { %>
  <div class="card p-12 text-center animate-in">
    <div class="w-14 h-14 rounded-full bg-brand-light mx-auto flex items-center justify-center mb-4">
      <svg class="w-7 h-7 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
      </svg>
    </div>
    <p class="text-mid">No submissions yet.</p>
    <a href="/" class="btn-primary inline-flex mt-4">Submit your first lead</a>
  </div>
  <% } else { %>
  <div class="card overflow-hidden animate-in">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-warm">
          <th class="text-left px-5 py-3 font-medium text-mid text-xs uppercase tracking-wider">Lead</th>
          <th class="text-left px-5 py-3 font-medium text-mid text-xs uppercase tracking-wider">Category</th>
          <th class="text-left px-5 py-3 font-medium text-mid text-xs uppercase tracking-wider">Status</th>
          <th class="text-left px-5 py-3 font-medium text-mid text-xs uppercase tracking-wider">Date</th>
        </tr>
      </thead>
      <tbody>
        <% submissions.forEach(function(sub) { %>
        <tr class="border-b border-warm last:border-0 hover:bg-gray-50 transition-colors">
          <td class="px-5 py-3.5">
            <a href="/submissions/<%= sub.id %>" class="font-medium text-brand hover:underline">
              <%= sub.leadFirstName %> <%= sub.leadLastName %>
            </a>
          </td>
          <td class="px-5 py-3.5 text-mid"><%= sub.category.label %></td>
          <td class="px-5 py-3.5">
            <span class="badge
              <%= sub.status === 'COMPLETE' ? 'badge-success' : '' %>
              <%= sub.status === 'FAILED' ? 'badge-error' : '' %>
              <%= sub.status === 'PROCESSING' ? 'badge-warning' : '' %>
            "><%= sub.status %></span>
          </td>
          <td class="px-5 py-3.5 text-mid"><%= sub.createdAt.toLocaleDateString('en-NZ') %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
