<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Performance Dashboard — Gerrards</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
  <style>
    :root{
      --bg:#0c0f17; --panel:#161a26; --panel2:#1d2130; --line:#272d3d;
      --ink:#e8edf7; --mid:#8b93a7; --accent:#ff7624;
      --c1:#34d3eb; --c2:#ff7624; --c3:#7c5cff; --c4:#22c55e; --c5:#f5b301; --c6:#ec4899;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--ink);padding:0 0 40px}
    .topbar{display:flex;align-items:center;justify-content:space-between;padding:18px 28px;border-bottom:1px solid var(--line);position:sticky;top:0;background:rgba(12,15,23,.9);backdrop-filter:blur(8px);z-index:10}
    .topbar h1{font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;font-size:26px;letter-spacing:.3px}
    .topbar .meta{color:var(--mid);font-size:13px}
    .topbar a{color:var(--mid);font-size:13px;text-decoration:none;border:1px solid var(--line);padding:7px 14px;border-radius:8px;transition:.15s}
    .topbar a:hover{color:var(--ink);border-color:var(--accent)}
    .wrap{padding:24px 28px;max-width:1680px;margin:0 auto}
    .kpis{display:grid;grid-template-columns:repeat(6,1fr);gap:16px;margin-bottom:22px}
    .kpi{background:linear-gradient(160deg,var(--panel2),var(--panel));border:1px solid var(--line);border-radius:14px;padding:18px 20px}
    .kpi .label{color:var(--mid);font-size:12px;text-transform:uppercase;letter-spacing:.6px;font-weight:600}
    .kpi .value{font-size:26px;font-weight:700;margin-top:8px;letter-spacing:-.5px}
    .kpi .sub{color:var(--mid);font-size:12px;margin-top:3px}
    .kpi.pos .value{color:var(--c4)} .kpi.warn .value{color:var(--c2)} .kpi.bad .value{color:#f87171}
    .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
    .panel{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:16px 18px 8px}
    .panel h2{font-size:13px;font-weight:600;color:#aeb8ff;letter-spacing:.4px;margin-bottom:6px}
    .panel .total{color:var(--mid);font-size:12px;margin-bottom:4px}
    .chart{width:100%;height:300px}
    .chart.tall{height:340px}
    .col-12{grid-column:span 12}.col-8{grid-column:span 8}.col-6{grid-column:span 6}.col-4{grid-column:span 4}.col-3{grid-column:span 3}
    .footnote{color:var(--mid);font-size:12px;margin-top:22px;line-height:1.6;border-top:1px solid var(--line);padding-top:14px}
    .footnote b{color:var(--ink)}
    #loading{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;background:var(--bg);color:var(--mid);font-size:14px;z-index:50}
    @media(max-width:1200px){.kpis{grid-template-columns:repeat(3,1fr)}.col-8,.col-6,.col-4,.col-3{grid-column:span 6}.col-12{grid-column:span 12}}
    @media(max-width:680px){.kpis{grid-template-columns:repeat(2,1fr)}.grid>div{grid-column:span 12!important}}
  </style>
</head>
<body>
  <div id="loading">Loading dashboard…</div>
  <div class="topbar">
    <div>
      <h1>Gerrards — Performance Dashboard</h1>
      <div class="meta" id="period">Broker production &amp; pipeline</div>
    </div>
    <a href="/">← Back to app</a>
  </div>

  <div class="wrap">
    <div class="kpis">
      <div class="kpi pos"><div class="label">Total Brokerage (GBI)</div><div class="value" id="k-gbi">—</div><div class="sub" id="k-gbi-sub"></div></div>
      <div class="kpi"><div class="label">New Business</div><div class="value" id="k-nb">—</div><div class="sub">gross broker income</div></div>
      <div class="kpi"><div class="label">Renewals</div><div class="value" id="k-renew">—</div><div class="sub">gross broker income</div></div>
      <div class="kpi bad"><div class="label">Cancellations</div><div class="value" id="k-cancel">—</div><div class="sub">income reversed</div></div>
      <div class="kpi warn"><div class="label">Lost Deals</div><div class="value" id="k-lost">—</div><div class="sub">from GHL</div></div>
      <div class="kpi"><div class="label">Enquiries Logged</div><div class="value" id="k-enq">—</div><div class="sub">phone / referral</div></div>
    </div>

    <div class="grid">
      <div class="panel col-8"><h2>MONTHLY GROSS BROKER INCOME BY BROKER</h2><div id="c-brokerMonth" class="chart tall"></div></div>
      <div class="panel col-4"><h2>NEW BUSINESS vs RENEWAL</h2><div id="c-nbGauge" class="chart tall"></div></div>

      <div class="panel col-6"><h2>GROSS BROKER INCOME BY BROKER</h2><div id="c-byBroker" class="chart"></div></div>
      <div class="panel col-6"><h2>INCOME BY TRANSACTION TYPE</h2><div id="c-byType" class="chart"></div></div>

      <div class="panel col-12"><h2>CUMULATIVE BROKERAGE PER DAY</h2><div id="c-perDay" class="chart"></div></div>

      <div class="panel col-6"><h2>LOSS REASONS</h2><div id="c-lostReason" class="chart"></div></div>
      <div class="panel col-6"><h2>LOST DEALS BY BROKER</h2><div id="c-lostBroker" class="chart"></div></div>

      <div class="panel col-6"><h2>NEW BUSINESS PER WEEK</h2><div id="c-nbWeek" class="chart"></div></div>
      <div class="panel col-6"><h2>LOST DEALS PER WEEK</h2><div id="c-lostWeek" class="chart"></div></div>

      <div class="panel col-8"><h2>TOP CLIENTS BY BROKERAGE</h2><div id="c-topClients" class="chart"></div></div>
      <div class="panel col-4"><h2>NEW ENQUIRIES PER DAY</h2><div id="c-enqDay" class="chart"></div></div>
    </div>

    <div class="footnote">
      <b>Live data:</b> broker earnings (CBN ledger), lost deals + reasons (GHL sync), enquiries (phone/referral app).
      &nbsp;<b>Not yet wired:</b> by-insurer (CBN carries no insurer — fills as brokers log wins on the form), calls per broker (Nuacom), speed-to-lead (lead-distribution system).
    </div>
  </div>

<script>
const PAL=['#34d3eb','#ff7624','#7c5cff','#22c55e','#f5b301','#ec4899','#38bdf8','#a3e635'];
const money=v=>'$'+Math.round(v||0).toLocaleString('en-NZ');
const moneyK=v=>{v=v||0;return Math.abs(v)>=1000?'$'+(v/1000).toFixed(v%1000?1:0)+'k':'$'+Math.round(v);};
const txt=(id,v)=>{const e=document.getElementById(id);if(e)e.textContent=v;};
const charts=[];
function mk(id,opt){const el=document.getElementById(id);if(!el)return;const c=echarts.init(el,null,{renderer:'canvas'});
  c.setOption(Object.assign({textStyle:{fontFamily:'DM Sans',color:'#8b93a7'},color:PAL,grid:{left:8,right:16,top:24,bottom:8,containLabel:true},
    tooltip:{trigger:'axis',backgroundColor:'#1d2130',borderColor:'#272d3d',textStyle:{color:'#e8edf7'}}},opt));charts.push(c);}
const axisX=(cat,rotate)=>({type:'category',data:cat,axisLine:{lineStyle:{color:'#272d3d'}},axisLabel:{color:'#8b93a7',fontSize:11,rotate:rotate||0},axisTick:{show:false}});
const axisYmoney=()=>({type:'value',splitLine:{lineStyle:{color:'#1d2130'}},axisLabel:{color:'#8b93a7',fontSize:11,formatter:v=>moneyK(v)}});
const axisYnum=()=>({type:'value',splitLine:{lineStyle:{color:'#1d2130'}},axisLabel:{color:'#8b93a7',fontSize:11}});

(async function(){
  let R;
  try{ R=await (await fetch('/dashboard/data')).json(); }catch(e){ document.getElementById('loading').textContent='Failed to load data.'; return; }
  document.getElementById('loading').style.display='none';

  // KPIs
  txt('k-gbi',money(R.kpis.totalGBI));
  txt('k-gbi-sub',R.kpis.brokerCount+' brokers · '+money(R.kpis.grossInvoice)+' GWP');
  txt('k-nb',money(R.kpis.newBizGBI));
  txt('k-renew',money(R.kpis.renewalGBI));
  txt('k-cancel',money(R.kpis.cancelGBI));
  txt('k-lost',(R.kpis.lostCount||0).toLocaleString('en-NZ'));
  txt('k-enq',(R.kpis.enquiryCount||0).toLocaleString('en-NZ'));
  const mm=R.brokerMonth.months;
  if(mm.length)document.getElementById('period').textContent='Period '+mm[0]+' → '+mm[mm.length-1]+'  ·  Gross Broker Income';

  // Monthly GBI by broker (stacked)
  mk('c-brokerMonth',{tooltip:{trigger:'axis',axisPointer:{type:'shadow'},valueFormatter:money,backgroundColor:'#1d2130',borderColor:'#272d3d',textStyle:{color:'#e8edf7'}},
    legend:{data:R.brokerMonth.series.map(s=>s.broker),textStyle:{color:'#8b93a7'},top:0,type:'scroll'},
    grid:{left:8,right:16,top:34,bottom:8,containLabel:true},
    xAxis:axisX(R.brokerMonth.months),yAxis:axisYmoney(),
    series:R.brokerMonth.series.map((s,i)=>({name:s.broker,type:'bar',stack:'gbi',data:s.data,itemStyle:{color:PAL[i%PAL.length]},emphasis:{focus:'series'}}))});

  // New business vs renewal gauge
  mk('c-nbGauge',{series:[{type:'gauge',startAngle:200,endAngle:-20,min:0,max:100,radius:'82%',center:['50%','58%'],
    progress:{show:true,width:16,itemStyle:{color:'#34d3eb'}},axisLine:{lineStyle:{width:16,color:[[1,'#1d2130']]}},
    pointer:{show:false},axisTick:{show:false},splitLine:{show:false},axisLabel:{show:false},
    anchor:{show:false},title:{show:true,offsetCenter:[0,'30%'],color:'#8b93a7',fontSize:13},
    detail:{valueAnimation:true,fontSize:34,offsetCenter:[0,'-5%'],formatter:'{value}%',color:'#e8edf7'},
    data:[{value:R.kpis.newBizPct,name:'New business share of income'}]}]});

  // GBI by broker (horizontal)
  const gb=R.gbiByBroker.slice().reverse();
  mk('c-byBroker',{tooltip:{trigger:'axis',axisPointer:{type:'shadow'},valueFormatter:money,backgroundColor:'#1d2130',borderColor:'#272d3d',textStyle:{color:'#e8edf7'}},
    grid:{left:8,right:60,top:10,bottom:8,containLabel:true},xAxis:axisYmoney(),
    yAxis:{type:'category',data:gb.map(b=>b.broker),axisLine:{lineStyle:{color:'#272d3d'}},axisLabel:{color:'#c9d1d9',fontSize:11},axisTick:{show:false}},
    series:[{type:'bar',data:gb.map(b=>b.gbi),itemStyle:{color:'#34d3eb',borderRadius:[0,4,4,0]},barWidth:'60%',
      label:{show:true,position:'right',color:'#8b93a7',fontSize:11,formatter:p=>moneyK(p.value)}}]});

  // Income by transaction type
  mk('c-byType',{tooltip:{trigger:'axis',axisPointer:{type:'shadow'},valueFormatter:money,backgroundColor:'#1d2130',borderColor:'#272d3d',textStyle:{color:'#e8edf7'}},
    grid:{left:8,right:16,top:10,bottom:8,containLabel:true},xAxis:axisX(R.gbiByType.map(t=>t.type),20),yAxis:axisYmoney(),
    series:[{type:'bar',data:R.gbiByType.map(t=>({value:t.gbi,itemStyle:{color:t.gbi<0?'#f87171':'#7c5cff',borderRadius:[4,4,0,0]}})),barWidth:'50%'}]});

  // Cumulative GBI per day (area)
  let cum=0;const cumData=R.gbiPerDay.map(d=>{cum+=d.gbi;return [d.day,Math.round(cum)];});
  mk('c-perDay',{tooltip:{trigger:'axis',valueFormatter:money,backgroundColor:'#1d2130',borderColor:'#272d3d',textStyle:{color:'#e8edf7'}},
    grid:{left:8,right:20,top:16,bottom:8,containLabel:true},
    xAxis:{type:'category',data:cumData.map(d=>d[0]),axisLine:{lineStyle:{color:'#272d3d'}},axisLabel:{color:'#8b93a7',fontSize:10},axisTick:{show:false}},
    yAxis:axisYmoney(),
    series:[{type:'line',data:cumData.map(d=>d[1]),smooth:true,showSymbol:false,lineStyle:{color:'#ff7624',width:2},
      areaStyle:{color:new echarts.graphic.LinearGradient(0,0,0,1,[{offset:0,color:'rgba(255,118,36,.35)'},{offset:1,color:'rgba(255,118,36,0)'}])}}]});

  // Loss reasons (horizontal)
  const lr=R.lostByReason.slice().reverse();
  mk('c-lostReason',{tooltip:{trigger:'axis',axisPointer:{type:'shadow'},backgroundColor:'#1d2130',borderColor:'#272d3d',textStyle:{color:'#e8edf7'}},
    grid:{left:8,right:40,top:10,bottom:8,containLabel:true},xAxis:axisYnum(),
    yAxis:{type:'category',data:lr.map(r=>r.reason),axisLine:{lineStyle:{color:'#272d3d'}},axisLabel:{color:'#c9d1d9',fontSize:11},axisTick:{show:false}},
    series:[{type:'bar',data:lr.map(r=>r.n),itemStyle:{color:'#ec4899',borderRadius:[0,4,4,0]},barWidth:'60%',label:{show:true,position:'right',color:'#8b93a7',fontSize:11}}]});

  // Lost by broker
  mk('c-lostBroker',{tooltip:{trigger:'axis',axisPointer:{type:'shadow'},backgroundColor:'#1d2130',borderColor:'#272d3d',textStyle:{color:'#e8edf7'}},
    grid:{left:8,right:16,top:10,bottom:8,containLabel:true},xAxis:axisX(R.lostByBroker.map(b=>b.broker),28),yAxis:axisYnum(),
    series:[{type:'bar',data:R.lostByBroker.map(b=>b.n),itemStyle:{color:'#f5b301',borderRadius:[4,4,0,0]},barWidth:'55%'}]});

  // New business per week
  mk('c-nbWeek',{tooltip:{trigger:'axis',axisPointer:{type:'shadow'},backgroundColor:'#1d2130',borderColor:'#272d3d',textStyle:{color:'#e8edf7'}},
    grid:{left:8,right:16,top:10,bottom:8,containLabel:true},xAxis:axisX(R.newBizPerWeek.map(w=>w.week),0),yAxis:axisYnum(),
    series:[{type:'bar',data:R.newBizPerWeek.map(w=>w.n),itemStyle:{color:'#22c55e',borderRadius:[4,4,0,0]},barWidth:'55%'}]});

  // Lost per week
  mk('c-lostWeek',{tooltip:{trigger:'axis',axisPointer:{type:'shadow'},backgroundColor:'#1d2130',borderColor:'#272d3d',textStyle:{color:'#e8edf7'}},
    grid:{left:8,right:16,top:10,bottom:8,containLabel:true},xAxis:axisX(R.lostPerWeek.map(w=>w.week),0),yAxis:axisYnum(),
    series:[{type:'bar',data:R.lostPerWeek.map(w=>w.n),itemStyle:{color:'#34d3eb',borderRadius:[4,4,0,0]},barWidth:'55%'}]});

  // Top clients (horizontal)
  const tc=R.topClients.slice().reverse();
  mk('c-topClients',{tooltip:{trigger:'axis',axisPointer:{type:'shadow'},valueFormatter:money,backgroundColor:'#1d2130',borderColor:'#272d3d',textStyle:{color:'#e8edf7'}},
    grid:{left:8,right:60,top:10,bottom:8,containLabel:true},xAxis:axisYmoney(),
    yAxis:{type:'category',data:tc.map(c=>c.client),axisLine:{lineStyle:{color:'#272d3d'}},axisLabel:{color:'#c9d1d9',fontSize:11,width:160,overflow:'truncate'},axisTick:{show:false}},
    series:[{type:'bar',data:tc.map(c=>c.gbi),itemStyle:{color:'#7c5cff',borderRadius:[0,4,4,0]},barWidth:'62%',label:{show:true,position:'right',color:'#8b93a7',fontSize:11,formatter:p=>moneyK(p.value)}}]});

  // Enquiries per day
  mk('c-enqDay',{tooltip:{trigger:'axis',axisPointer:{type:'shadow'},backgroundColor:'#1d2130',borderColor:'#272d3d',textStyle:{color:'#e8edf7'}},
    grid:{left:8,right:12,top:10,bottom:8,containLabel:true},xAxis:axisX(R.enquiriesPerDay.map(d=>d.day.slice(5)),0),yAxis:axisYnum(),
    series:[{type:'bar',data:R.enquiriesPerDay.map(d=>d.n),itemStyle:{color:'#38bdf8',borderRadius:[3,3,0,0]}}]});
})();

window.addEventListener('resize',()=>charts.forEach(c=>c.resize()));
</script>
</body>
</html>
