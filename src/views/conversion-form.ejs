<%
  // small helpers to keep the markup readable
  const v = (k, d = '') => (typeof values !== 'undefined' && values[k] != null && values[k] !== '') ? values[k] : d;
  const err = (k) => (typeof errors !== 'undefined' && errors[k]) ? errors[k] : null;
  const LOST_LABELS = {
    WENT_DIRECT: 'Went direct to insurer',
    PRICE: 'Price / premium too high',
    INCUMBENT_BROKER: 'Stayed with incumbent broker',
    NO_APPETITE: 'No insurer appetite (couldn’t place)',
    CUSTOMER_WITHDREW: 'Customer withdrew / not proceeding',
    OTHER: 'Other',
  };
  const BIZ_LABELS = { NEW_BUSINESS: 'New business', RENEWAL: 'Renewal' };
%>
<div class="max-w-2xl mx-auto animate-in">
  <div class="mb-6">
    <a href="/my-conversions" class="text-sm text-mid hover:text-brand transition-colors">&larr; My conversions</a>
    <h1 class="font-serif text-2xl italic mt-2" style="color: var(--brand-dark);">Log a Conversion</h1>
    <% if (fromSubmission) { %>
    <p class="text-mid text-sm mt-1">From lead: <span class="font-medium"><%= fromSubmission.leadFirstName %> <%= fromSubmission.leadLastName %></span> — outcome will sync to GHL.</p>
    <% } else { %>
    <p class="text-mid text-sm mt-1">Record a won or lost deal. Dollar figures are your estimate at bind.</p>
    <% } %>
  </div>

  <form method="POST" action="/conversions/new" class="card p-6 sm:p-8 space-y-5"
        x-data="conversionForm()">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="submit_token" value="<%= typeof submitToken !== 'undefined' ? submitToken : '' %>">
    <input type="hidden" name="submission_id" value="<%= v('submission_id') %>">
    <input type="hidden" name="ghl_contact_id" value="<%= v('ghl_contact_id') %>">
    <input type="hidden" name="ghl_opportunity_id" value="<%= v('ghl_opportunity_id') %>">

    <!-- Client -->
    <div>
      <label for="client_name" class="block text-sm font-medium mb-1.5">Client / business name *</label>
      <input type="text" id="client_name" name="client_name" value="<%= v('client_name') %>"
             class="input-field <%= err('client_name') ? 'error' : '' %>">
      <% if (err('client_name')) { %><p class="text-red-600 text-xs mt-1"><%= err('client_name') %></p><% } %>
    </div>

    <!-- Outcome toggle -->
    <div>
      <span class="block text-sm font-medium mb-1.5">Outcome *</span>
      <div class="grid grid-cols-2 gap-3">
        <label class="cursor-pointer">
          <input type="radio" name="outcome" value="WON" class="sr-only peer" x-model="outcome" <%= v('outcome') === 'WON' ? 'checked' : '' %>>
          <div class="text-center py-3 rounded-lg border text-sm font-medium transition-all"
               :class="outcome === 'WON' ? 'border-brand bg-brand-light text-brand' : 'border-warm text-mid'">Won ✓</div>
        </label>
        <label class="cursor-pointer">
          <input type="radio" name="outcome" value="LOST" class="sr-only peer" x-model="outcome" <%= v('outcome') === 'LOST' ? 'checked' : '' %>>
          <div class="text-center py-3 rounded-lg border text-sm font-medium transition-all"
               :class="outcome === 'LOST' ? 'border-red-400 bg-red-50 text-red-700' : 'border-warm text-mid'">Lost</div>
        </label>
      </div>
      <% if (err('outcome')) { %><p class="text-red-600 text-xs mt-1"><%= err('outcome') %></p><% } %>
    </div>

    <!-- ===================== WON ===================== -->
    <div x-show="outcome === 'WON'" x-cloak class="space-y-5 border-t border-warm pt-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="business_type" class="block text-sm font-medium mb-1.5">Business type *</label>
          <select id="business_type" name="business_type" class="input-field <%= err('business_type') ? 'error' : '' %>">
            <option value="">Select...</option>
            <% businessTypes.forEach(function(bt) { %>
            <option value="<%= bt %>" <%= v('business_type') === bt ? 'selected' : '' %>><%= BIZ_LABELS[bt] %></option>
            <% }); %>
          </select>
          <% if (err('business_type')) { %><p class="text-red-600 text-xs mt-1"><%= err('business_type') %></p><% } %>
        </div>
        <div>
          <label for="insurance_category_id" class="block text-sm font-medium mb-1.5">Class of business *</label>
          <select id="insurance_category_id" name="insurance_category_id" class="input-field <%= err('insurance_category_id') ? 'error' : '' %>">
            <option value="">Select...</option>
            <% categories.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= v('insurance_category_id') === c.id ? 'selected' : '' %>><%= c.label %></option>
            <% }); %>
          </select>
          <% if (err('insurance_category_id')) { %><p class="text-red-600 text-xs mt-1"><%= err('insurance_category_id') %></p><% } %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="insurer_id" class="block text-sm font-medium mb-1.5">Insurer *</label>
          <select id="insurer_id" name="insurer_id" class="input-field <%= err('insurer_id') ? 'error' : '' %>"
                  x-model="insurerId" @change="onInsurerChange($event)">
            <option value="" data-pct="0">Select...</option>
            <% insurers.forEach(function(ins) { %>
            <option value="<%= ins.id %>" data-pct="<%= ins.defaultCommissionPct %>" <%= v('insurer_id') === ins.id ? 'selected' : '' %>><%= ins.label %></option>
            <% }); %>
          </select>
          <% if (err('insurer_id')) { %><p class="text-red-600 text-xs mt-1"><%= err('insurer_id') %></p><% } %>
        </div>
        <div>
          <label for="policies_bound" class="block text-sm font-medium mb-1.5">Policies bound</label>
          <input type="number" min="1" id="policies_bound" name="policies_bound" value="<%= v('policies_bound', '1') %>" class="input-field">
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="annual_premium" class="block text-sm font-medium mb-1.5">Annual premium (GWP) *</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mid text-sm">$</span>
            <input type="text" inputmode="decimal" id="annual_premium" name="annual_premium" value="<%= v('annual_premium') %>"
                   x-model="premium" class="input-field pl-7 <%= err('annual_premium') ? 'error' : '' %>" placeholder="0.00">
          </div>
          <% if (err('annual_premium')) { %><p class="text-red-600 text-xs mt-1"><%= err('annual_premium') %></p><% } %>
        </div>
        <div>
          <label for="inception_date" class="block text-sm font-medium mb-1.5">Inception date</label>
          <input type="date" id="inception_date" name="inception_date" value="<%= v('inception_date') %>" class="input-field">
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="base_commission_pct" class="block text-sm font-medium mb-1.5">Commission %</label>
          <div class="relative">
            <input type="text" inputmode="decimal" id="base_commission_pct" name="base_commission_pct" value="<%= v('base_commission_pct') %>"
                   x-model="pct" class="input-field pr-7" :placeholder="insurerPct ? insurerPct + ' (insurer default)' : 'auto from insurer'">
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mid text-sm">%</span>
          </div>
          <p class="text-mid text-xs mt-1">Leave blank to use the insurer’s default rate.</p>
        </div>
        <div>
          <label for="broker_fee" class="block text-sm font-medium mb-1.5">Broker fee (charged to client)</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mid text-sm">$</span>
            <input type="text" inputmode="decimal" id="broker_fee" name="broker_fee" value="<%= v('broker_fee') %>"
                   x-model="fee" class="input-field pl-7" placeholder="0.00">
          </div>
        </div>
      </div>

      <!-- Premium funding -->
      <div>
        <label class="flex items-center gap-2.5 cursor-pointer">
          <input type="checkbox" name="premium_funded" x-model="funded" <%= v('premium_funded') ? 'checked' : '' %>
                 class="w-4 h-4 rounded border-warm text-brand focus:ring-brand">
          <span class="text-sm font-medium">Premium funding arranged</span>
        </label>
        <div x-show="funded" x-cloak class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-3">
          <div>
            <label for="funder" class="block text-sm font-medium mb-1.5">Funder</label>
            <input type="text" id="funder" name="funder" value="<%= v('funder') %>" class="input-field" placeholder="e.g. Hunter Premium Funding">
          </div>
          <div>
            <label for="funding_commission" class="block text-sm font-medium mb-1.5">Funding commission</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mid text-sm">$</span>
              <input type="text" inputmode="decimal" id="funding_commission" name="funding_commission" value="<%= v('funding_commission') %>"
                     x-model="funding" class="input-field pl-7" placeholder="0.00">
            </div>
          </div>
        </div>
      </div>

      <!-- Live brokerage estimate -->
      <div class="bg-brand-light rounded-lg p-4 flex items-center justify-between">
        <div>
          <p class="text-xs text-mid uppercase tracking-wider">Estimated brokerage</p>
          <p class="text-xs text-mid mt-0.5">premium × <span x-text="effPct().toFixed(2)"></span>% + fees</p>
        </div>
        <p class="text-2xl font-semibold text-brand">$<span x-text="brokerage().toLocaleString('en-NZ', {minimumFractionDigits: 2, maximumFractionDigits: 2})"></span></p>
      </div>
    </div>

    <!-- ===================== LOST ===================== -->
    <div x-show="outcome === 'LOST'" x-cloak class="space-y-5 border-t border-warm pt-5">
      <div>
        <label for="lost_reason" class="block text-sm font-medium mb-1.5">Reason lost *</label>
        <select id="lost_reason" name="lost_reason" class="input-field <%= err('lost_reason') ? 'error' : '' %>">
          <option value="">Select...</option>
          <% lostReasons.forEach(function(r) { %>
          <option value="<%= r %>" <%= v('lost_reason') === r ? 'selected' : '' %>><%= LOST_LABELS[r] %></option>
          <% }); %>
        </select>
        <% if (err('lost_reason')) { %><p class="text-red-600 text-xs mt-1"><%= err('lost_reason') %></p><% } %>
      </div>
      <div>
        <label for="competitor" class="block text-sm font-medium mb-1.5">Who won it? (optional)</label>
        <input type="text" id="competitor" name="competitor" value="<%= v('competitor') %>" class="input-field" placeholder="Competitor / incumbent broker">
      </div>
    </div>

    <!-- Notes (both paths) -->
    <div x-show="outcome" x-cloak>
      <label for="notes" class="block text-sm font-medium mb-1.5">Notes</label>
      <textarea id="notes" name="notes" rows="3" class="input-field"><%= v('notes') %></textarea>
    </div>

    <div class="pt-2">
      <button type="submit" id="submit-conversion-btn" class="btn-primary w-full py-3 disabled:opacity-60 disabled:cursor-not-allowed">
        <span data-label>Log conversion</span>
      </button>
    </div>
  </form>
</div>

<script>
  function conversionForm() {
    const n = (val) => { const x = parseFloat(String(val).replace(/[$,\s]/g, '')); return isFinite(x) ? x : 0; };
    return {
      outcome: '<%= v("outcome") %>',
      insurerId: '<%= v("insurer_id") %>',
      insurerPct: 0,
      premium: '<%= v("annual_premium") %>',
      pct: '<%= v("base_commission_pct") %>',
      fee: '<%= v("broker_fee") %>',
      funding: '<%= v("funding_commission") %>',
      funded: <%= v('premium_funded') ? 'true' : 'false' %>,
      init() {
        const sel = document.getElementById('insurer_id');
        if (sel && sel.selectedOptions[0]) this.insurerPct = n(sel.selectedOptions[0].dataset.pct);
      },
      onInsurerChange(e) {
        const opt = e.target.selectedOptions[0];
        this.insurerPct = opt ? n(opt.dataset.pct) : 0;
      },
      effPct() { return n(this.pct) > 0 ? n(this.pct) : this.insurerPct; },
      brokerage() {
        const base = n(this.premium) * this.effPct() / 100;
        return base + n(this.fee) + (this.funded ? n(this.funding) : 0);
      },
    };
  }

  // Double-submit guard (mirrors the lead form).
  (function () {
    var form = document.querySelector('form[action="/conversions/new"]');
    if (!form) return;
    var btn = document.getElementById('submit-conversion-btn');
    var submitting = false;
    form.addEventListener('submit', function (e) {
      if (submitting) { e.preventDefault(); return; }
      submitting = true;
      if (btn) { btn.disabled = true; var l = btn.querySelector('[data-label]'); if (l) l.textContent = 'Saving…'; }
    });
  })();
</script>
