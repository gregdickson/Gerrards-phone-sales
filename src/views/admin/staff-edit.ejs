<div class="max-w-lg mx-auto animate-in">
  <div class="mb-6">
    <a href="/admin/staff" class="text-sm text-mid hover:text-brand transition-colors">&larr; Back to staff</a>
    <h1 class="font-serif text-2xl italic mt-2" style="color: var(--brand-dark);"><%= staffMember && staffMember.id ? 'Edit' : 'Add' %> Staff Member</h1>
  </div>

  <form method="POST" action="<%= staffMember && staffMember.id ? '/admin/staff/' + staffMember.id : '/admin/staff' %>"
        class="card p-6 sm:p-8 space-y-5">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div>
      <label for="name" class="block text-sm font-medium mb-1.5">Name *</label>
      <input type="text" id="name" name="name"
             value="<%= staffMember ? staffMember.name || '' : '' %>"
             required class="input-field <%= errors.name ? 'error' : '' %>">
      <% if (errors.name) { %><p class="text-red-600 text-xs mt-1"><%= errors.name %></p><% } %>
    </div>

    <div>
      <label for="email" class="block text-sm font-medium mb-1.5">Email *</label>
      <input type="email" id="email" name="email"
             value="<%= staffMember ? staffMember.email || '' : '' %>"
             required class="input-field <%= errors.email ? 'error' : '' %>">
      <% if (errors.email) { %><p class="text-red-600 text-xs mt-1"><%= errors.email %></p><% } %>
    </div>

    <div>
      <label for="ghl_user_id" class="block text-sm font-medium mb-1.5">GHL User ID *</label>
      <% if (ghlUsers && ghlUsers.length > 0) { %>
      <select id="ghl_user_id" name="ghl_user_id" required class="input-field">
        <option value="">Select GHL user...</option>
        <% ghlUsers.forEach(function(u) { %>
        <option value="<%= u.id %>" <%= (staffMember && (staffMember.ghl_user_id === u.id || staffMember.ghlUserId === u.id)) ? 'selected' : '' %>>
          <%= u.name || u.email %> (<%= u.id %>)
        </option>
        <% }); %>
      </select>
      <% } else { %>
      <input type="text" id="ghl_user_id" name="ghl_user_id"
             value="<%= staffMember ? staffMember.ghl_user_id || staffMember.ghlUserId || '' : '' %>"
             required placeholder="Paste GHL user ID"
             class="input-field <%= errors.ghl_user_id ? 'error' : '' %>">
      <% } %>
      <% if (errors.ghl_user_id) { %><p class="text-red-600 text-xs mt-1"><%= errors.ghl_user_id %></p><% } %>
    </div>

    <div>
      <label for="webhook_url" class="block text-sm font-medium mb-1.5">Webhook URL</label>
      <input type="url" id="webhook_url" name="webhook_url"
             value="<%= staffMember ? staffMember.webhook_url || staffMember.webhookUrl || '' : '' %>"
             placeholder="https://automation.bridgemedia.nz/webhook/..."
             class="input-field">
    </div>

    <div>
      <label for="role" class="block text-sm font-medium mb-1.5">Role</label>
      <select id="role" name="role" class="input-field">
        <option value="STAFF" <%= (!staffMember || staffMember.role === 'STAFF') ? 'selected' : '' %>>Staff</option>
        <option value="ADMIN" <%= (staffMember && staffMember.role === 'ADMIN') ? 'selected' : '' %>>Admin</option>
      </select>
    </div>

    <div class="pt-2">
      <button type="submit" class="btn-primary w-full">
        <%= staffMember && staffMember.id ? 'Update' : 'Create' %> Staff Member
      </button>
    </div>
  </form>
</div>
