# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gerrards_phone

# App
APP_URL=http://localhost:3000
COOKIE_SECRET=replace-with-random-64-char-hex
PORT=3000

# GHL
GHL_API_KEY=your-ghl-private-integration-token
GHL_LOCATION_ID=your-ghl-location-id
GHL_PIPELINE_ID=your-ghl-pipeline-id
GHL_STAGE_ID=your-ghl-stage-id

# Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.gerrards.co.nz
MAILGUN_EU=false
EMAIL_FROM=noreply@gerrards.co.nz

# Google Places
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Seed (used by prisma/seed.js for initial admin user)
ADMIN_EMAIL=admin@gerrards.co.nz
ADMIN_NAME=Admin
ADMIN_GHL_USER_ID=your-admin-ghl-user-id
