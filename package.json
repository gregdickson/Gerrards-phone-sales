{
  "name": "gerrards-phone-referral",
  "version": "1.0.0",
  "description": "Gerrards Insurance phone and referral lead capture app",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node prisma/seed.js",
    "css:build": "npx tailwindcss -i src/input.css -o public/css/output.css --minify",
    "css:watch": "npx tailwindcss -i src/input.css -o public/css/output.css --watch"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^9.1.3",
    "@fastify/view": "^11.1.1",
    "@prisma/client": "^5.22.0",
    "ejs": "^5.0.2",
    "fastify": "^5.8.5",
    "form-data": "^4.0.5",
    "mailgun.js": "^13.0.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19"
  }
}
